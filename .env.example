# Bitbank.nz API key (get from https://bitbank.nz - sign up, go to API page)
BITBANK_API_KEY=your_bitbank_api_key_here
BITBANK_BASE_URL=https://bitbank.nz

# Binance API credentials (https://www.binance.com/en/my/settings/api-management)
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# For US users, use Binance.US:
# BINANCE_BASE_URL=https://api.binance.us
# For non-US users (default):
# BINANCE_BASE_URL=https://api.binance.com

# Trading config
TRADING_CAPITAL=1000.0
# Minimum 7d PnL % to consider a pair tradable
MIN_PNL_7D_PCT=0.0
# Entry tolerance in basis points (5bp = 0.05%)
ENTRY_TOLERANCE_BP=5
# Dry run mode (no real trades)
DRY_RUN=true
